# Copy this to .env and fill in your values
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Directory Claude Code operates in (default: /data/w/exx)
CLAUDE_WORK_DIR=/data/w/exx

# Allow Claude to run tools without permission prompts (default: true)
CLAUDE_SKIP_PERMISSIONS=true

# Restrict access to specific Telegram user IDs (comma-separated, empty = allow all)
# Get your ID by messaging @userinfobot on Telegram
ALLOWED_USERS=
